<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/ruleTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="🌧️ 下雨天专属"
            android:textColor="#2d2a24"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="触发词："
                android:textColor="#8b7f6e"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tagsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下雨, 阴天, 湿冷"
                android:textColor="#4e4539"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="推荐："
                android:textColor="#8b7f6e"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/foodsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="麻辣烫, 拉面, 酸辣粉"
                android:textColor="#4e4539"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/editBtn"
                style="@style/RuleActionButton"
                android:text="编辑" />

            <Button
                android:id="@+id/deleteBtn"
                style="@style/RuleActionButton"
                android:layout_marginStart="12dp"
                android:text="删除"
                android:textColor="#d9534f" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>